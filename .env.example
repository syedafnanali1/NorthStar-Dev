# ================================================================
# NORTH STAR — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to git
# ================================================================

# ── DATABASE ──────────────────────────────────────────────────
# Get from: https://neon.tech (free tier)
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/northstar?sslmode=require"
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/northstar?sslmode=require"
# ── AUTH ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET="your-32-char-random-secret-here"
AUTH_SECURITY_SECRET="your-32-char-random-security-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# If OAuth consent is in "Testing", only listed Test users can sign in.
# For broader QA access, publish to Production or add each tester email.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Facebook OAuth — https://developers.facebook.com
# Valid OAuth Redirect URIs: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID="your-facebook-app-id"
FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# ── EMAIL (Resend) ─────────────────────────────────────────────
# Get from: https://resend.com (free up to 3000 emails/month)
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="North Star <hello@yourdomain.com>"
# onboarding@resend.dev is sandbox-only and can send only to your own Resend account email.
# Use a verified custom domain for multi-user testing and production.

# Optional OAuth step-up verification scope:
# all   = require step-up for all OAuth users (default)
# admin = require step-up only for listed admin emails
# off   = disable OAuth step-up verification
# AUTH_STEP_UP_SCOPE="all"
# AUTH_STEP_UP_ADMIN_EMAILS="admin1@yourdomain.com,admin2@yourdomain.com"

# ── SMS (Twilio) ───────────────────────────────────────────────
# Get from: https://twilio.com (free trial with test number)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15551234567"

# ── AI (Anthropic) ────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="North Star"

# ── CRON ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Used to authenticate Vercel Cron job requests
CRON_SECRET="your-cron-secret-here"

# ── FILE UPLOADS (optional - for avatar uploads) ──────────────
# Get from: https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxxxxxxxxx"
